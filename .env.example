# Copy this file to .env and fill in real values before starting the app.
# The app will refuse to start if ADMIN_PASSWORD is missing.

# Flask secret key — generated automatically on first run if omitted,
# but set explicitly for multi-process deployments (Gunicorn, etc.)
SECRET_KEY=

# Admin login credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Spotify API credentials — required for Spotify track/playlist support.
# Create an app at https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Set to 1 to enable Flask debug mode (never in production)
FLASK_DEBUG=0
